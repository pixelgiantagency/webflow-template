{
  "name": "webflow-template",
  "version": "0.1.0",
  "description": "PixelGiant Webflow custom-code template (TypeScript + esbuild + GitHub Actions + jsDelivr)",
  "license": "UNLICENSED",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --minify --outfile=dist/bundle.js",
    "dev": "esbuild src/main.ts --bundle --outfile=dist/bundle.js --servedir=dist --serve=3000",
    "check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "gsap": "^3.15.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
